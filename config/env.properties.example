#!/bin/bash
# =============================================================================
# env.properties — Central configuration for all components
# =============================================================================
# Copy this file to config/env.properties and fill in your values.
# The deploy scripts source this file; all URLs are computed automatically
# by scripts/utils.sh from these base values.
# =============================================================================

# -- OpenShift Cluster --------------------------------------------------------
CLUSTER_DOMAIN=apps.ocp.example.com

# -- Namespace ----------------------------------------------------------------
# All workloads (pgvector, LlamaStack, Redis, Agent, Router, MCP servers)
# run in a single namespace.  Set all three NS_* vars to the same value.
NS_SERVICES=agentic-service
NS_PGVECTOR=${NS_SERVICES}
NS_LLAMASTACK=${NS_SERVICES}
NS_MODELS=${NS_SERVICES}

# -- Container Images ---------------------------------------------------------
IMAGE_AGENT=quay.io/sidde3/agent-service:latest
IMAGE_ROUTER=quay.io/sidde3/router-service:latest
IMAGE_USAGE_MCP=quay.io/sidde3/usage-mcp-server:latest
IMAGE_HELLO_MCP=quay.io/sidde3/hello-mcp-server:latest
IMAGE_USERINFO_API=quay.io/sidde3/userinfo-api:latest
IMAGE_USERINFO_MCP=quay.io/sidde3/userinfo-api-mcp:latest

# -- PostgreSQL ---------------------------------------------------------------
PGVECTOR_USER=appuser
PGVECTOR_PASSWORD=apppassword
# Bootstrap database for admin (must match POSTGRES_DB on the pod). Use `postgres` if that is your image default.
PGVECTOR_DB=pgvector

PG_USERINFO_USER=user_info
PG_USERINFO_PASSWORD=secret
PG_LLAMASTACK_USER=llamastack
PG_LLAMASTACK_PASSWORD=secret

# -- Redis --------------------------------------------------------------------
REDIS_PASSWORD=routerRedis123

# -- AI Models ----------------------------------------------------------------
INFERENCE_MODEL=vllm-inference/qwen25-7b-instruct
BERT_MODEL_NAME=finetuned-phayathai-bert
EMBEDDING_MODEL_NAME=bge-small-en-v15
RERANKER_MODEL=qwen3-reranker-06b

# -- LlamaStack rh-dev (LlamaStackDistribution containerSpec) -----------------
# Optional: full OpenShift Route URLs if they do not follow
#   https://<inference-short-name>-<NS_MODELS>.<CLUSTER_DOMAIN>/v1
# VLLM_URL=https://your-inference-route.../v1
# VLLM_EMBEDDING_URL=https://your-embedding-route.../v1
# Optional overrides (defaults set in scripts/utils.sh):
# POSTGRES_HOST=pgvector.${NS_PGVECTOR}.svc.cluster.local
# LLS_INFERENCE_MODEL_ID=qwen25-7b-instruct
# EMBEDDING_PROVIDER_MODEL_ID=bge-small-en-v15
# ENABLE_PGVECTOR=true
# LLAMASTACK_DISTRIBUTION_NAME=rh-dev
# If pod logs list built-in "rh" but startup still fails, try: LLAMASTACK_DISTRIBUTION_NAME=rh

# -- Feature Flags ------------------------------------------------------------
RERANK_ENABLED=true
RERANK_TOP_K=20
RERANK_TOP_N=5
ENABLE_VECTOR_INGESTION=true

# -- Agent --------------------------------------------------------------------
# Vector store ID — auto-detected during deploy by 01-create-vector-store.sh.
# Leave as "auto" for first-time setup, or set a specific vs_* ID to reuse
# an existing store (find with: curl -sk <LLAMASTACK_URL>/v1/vector_stores).
VECTOR_DB_ID=auto
MCP_TOOLGROUP=userinfo-mcp-server

# -- Router -------------------------------------------------------------------
BERT_CONFIDENCE_THRESHOLD=0.4
MAX_TURNS=5

# =============================================================================
# Computed URLs (derived automatically by scripts/utils.sh — do NOT set here)
# =============================================================================
# PGVECTOR_HOST      = pgvector.${NS_PGVECTOR}.svc.cluster.local
# REDIS_HOST         = redis.${NS_SERVICES}.svc.cluster.local
# LLAMASTACK_URL     = https://llamastack-${NS_LLAMASTACK}.${CLUSTER_DOMAIN}
# LLAMASTACK_INTERNAL= http://llamastack-custom-distribution.${NS_LLAMASTACK}.svc.cluster.local:8321
# BERT_URL           = https://${BERT_MODEL_NAME}-${NS_MODELS}.${CLUSTER_DOMAIN}
# RERANKER_URL       = https://${RERANKER_MODEL}-${NS_MODELS}.${CLUSTER_DOMAIN}/v1/rerank
# VLLM_INTERNAL_URL  = http://<inference-model>-predictor.${NS_MODELS}.svc.cluster.local/v1
# EMBEDDING_INTERNAL_URL = http://${EMBEDDING_MODEL_NAME}-predictor.${NS_MODELS}.svc.cluster.local/v1
# AGENT_ROUTE_URL    = https://agent-service-${NS_SERVICES}.${CLUSTER_DOMAIN}
# ROUTER_ROUTE_URL   = https://router-service-${NS_SERVICES}.${CLUSTER_DOMAIN}
# AGENT_INTERNAL     = http://agent-service.${NS_SERVICES}.svc.cluster.local:8080
# USERINFO_API_URL   = http://userinfo-api.${NS_SERVICES}.svc.cluster.local:8000
