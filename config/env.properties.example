#!/bin/bash
# ============================================================================
# env.properties — Central configuration for all components
# ============================================================================
# Copy this file to config/env.properties and fill in your values.
# The deploy scripts source this file and use envsubst on manifests.
# ============================================================================

# -- Cluster -----------------------------------------------------------------
CLUSTER_DOMAIN=apps.ocp.bhqd8.sandbox1981.opentlc.com

# -- Namespaces --------------------------------------------------------------
NS_PGVECTOR=pg-vector
NS_MODELS=intent-classification-sidd
NS_LLAMASTACK=llamastack
NS_SERVICES=agentic-service

# -- Container Images (quay.io) ---------------------------------------------
IMAGE_AGENT=quay.io/sidde3/agent-service:latest
IMAGE_ROUTER=quay.io/sidde3/router-service:latest
IMAGE_USAGE_MCP=quay.io/sidde3/usage-mcp-server:latest
IMAGE_HELLO_MCP=quay.io/sidde3/hello-mcp-server:latest
IMAGE_USERINFO_API=quay.io/sidde3/userinfo-api:latest
IMAGE_USERINFO_MCP=quay.io/sidde3/userinfo-api-mcp:latest

# -- PostgreSQL + pgvector (single instance in pg-vector namespace) ----------
PGVECTOR_USER=appuser
PGVECTOR_PASSWORD=apppassword
PGVECTOR_DB=pgvector

PG_USERINFO_USER=user_info
PG_USERINFO_PASSWORD=secret
PG_LLAMASTACK_USER=llamastack
PG_LLAMASTACK_PASSWORD=secret

# -- Redis -------------------------------------------------------------------
REDIS_PASSWORD=routerRedis123

# -- Models ------------------------------------------------------------------
INFERENCE_MODEL=vllm-inference/qwen25-7b-instruct
BERT_MODEL_NAME=finetuned-phayathai-bert

# -- Llama Stack -------------------------------------------------------------
# Internal URL the Llama Stack container uses to reach the vLLM model
VLLM_INTERNAL_URL=http://qwen25-7b-instruct-predictor.${NS_MODELS}.svc.cluster.local/v1

# -- Vector Ingestion --------------------------------------------------------
# Set to "true" to create a vector store and ingest plan documents during
# deploy-all.sh post-deploy phase. Set to "false" when using Kubeflow
# Pipelines for vector ingestion or when redeploying to an existing cluster.
ENABLE_VECTOR_INGESTION=true

# -- Agent -------------------------------------------------------------------
# Vector store ID — auto-detected during deploy by 01-create-vector-store.sh.
# Leave as "auto" for automatic setup, or set a specific vs_* ID to reuse
# an existing store (find with: curl -sk https://llamastack-.../v1/vector_stores)
VECTOR_DB_ID=auto
MCP_TOOLGROUP=userinfo-mcp-server

# -- Reranker ----------------------------------------------------------------
# Reranker model endpoint for post-retrieval reranking of knowledge_search results.
# When set, the agent searches the vector store, reranks results via this endpoint,
# and injects the top-N reranked plan documents into the LLM context.
RERANKER_URL=https://qwen3-reranker-06b-intent-classification-sidd.apps.ocp.bhqd8.sandbox1981.opentlc.com/v1/rerank
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_TOP_K=20
RERANK_TOP_N=5

# -- Router ------------------------------------------------------------------
BERT_CONFIDENCE_THRESHOLD=0.4
MAX_TURNS=5

# ============================================================================
# Computed URLs (derived at deploy time by scripts/utils.sh)
# ============================================================================
# PGVECTOR_HOST    = pgvector.${NS_PGVECTOR}.svc.cluster.local
# LLAMASTACK_URL   = https://llamastack-${NS_LLAMASTACK}.${CLUSTER_DOMAIN}
# BERT_URL         = https://${BERT_MODEL_NAME}-${NS_MODELS}.${CLUSTER_DOMAIN}
# AGENT_ROUTE_URL  = https://agent-service-${NS_SERVICES}.${CLUSTER_DOMAIN}
# ROUTER_ROUTE_URL = https://router-service-${NS_SERVICES}.${CLUSTER_DOMAIN}
# REDIS_HOST       = redis.${NS_SERVICES}.svc.cluster.local
# AGENT_INTERNAL   = http://agent-service.${NS_SERVICES}.svc.cluster.local:8080
# MCP_INTERNAL     = http://usage-mcp-server-v2.${NS_SERVICES}.svc.cluster.local:8000
# USERINFO_API_URL = http://userinfo-api.${NS_SERVICES}.svc.cluster.local:8000
# USERINFO_MCP_URL = http://userinfo-mcp-server.${NS_SERVICES}.svc.cluster.local:8000
